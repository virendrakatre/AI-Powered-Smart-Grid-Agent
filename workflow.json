      "parameters": {
        "jsCode": "// Get current weather data from previous node\nconst weatherData = $json.current || { cloud_cover: 50, temperature_2m: 30 };\nconst cloudCover = weatherData.cloud_cover;\n\n// Simulate realistic industrial load based on current hour\nconst currentHour = new Date().getHours();\nlet baseLoad = 150; // Base load in kW\n\nif (currentHour >= 10 && currentHour <= 17) {\n  baseLoad += Math.floor(Math.random() * 100) + 150; // Peak hours: 250kW - 400kW\n} else {\n  baseLoad += Math.floor(Math.random() * 50); // Off-peak hours\n}\n\n// Generate battery State of Charge (SoC)\nconst batterySoC = Math.floor(Math.random() * 40) + 50; // 50% to 90%\n\nreturn [{\n  json: {\n    timestamp: new Date().toISOString(),\n    location: \"Nagpur, India\",\n    weather: {\n      cloud_cover_percent: cloudCover,\n      temperature_c: weatherData.temperature_2m\n    },\n    grid_metrics: {\n      factory_current_load_kw: baseLoad,\n      battery_storage_soc_percent: batterySoC\n    }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
